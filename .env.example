# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# regru.py читает .env автоматически. Файл .env в .gitignore — не коммитится.
#
# REGRU_USERNAME — логин от личного кабинета reg.ru.
# REGRU_PASSWORD — АЛЬТЕРНАТИВНЫЙ пароль для API, заданный в кабинете
#                  (https://www.reg.ru/user/account/settings/api/),
#                  а НЕ пароль от личного кабинета.
#
# Также нужно добавить ваш внешний IP в whitelist в том же разделе кабинета,
# узнать IP: curl ifconfig.me

REGRU_USERNAME=
REGRU_PASSWORD=
